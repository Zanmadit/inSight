# =============================================================================
# inVision U — example environment (demo values; change for production)
# Copy to .env:  cp .env.example .env
# Docker Compose builds backend DATABASE_URL from POSTGRES_* — keep them aligned.
# =============================================================================

# PostgreSQL
POSTGRES_USER=invision
POSTGRES_PASSWORD=InvisionPgDemo2026
POSTGRES_DB=invision_db

# Optional: local backend on host (not Docker). Must match POSTGRES_* above if same DB.
# DATABASE_URL=postgresql+asyncpg://invision:InvisionPgDemo2026@localhost:5432/invision_db

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=MinioLocalDemo2026
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=invision-videos
MINIO_PUBLIC_URL=http://localhost:9000

# OpenAI (set your key in .env; leave blank in committed copies)
OPENAI_API_KEY=

# Auth (use a long random secret in production)
JWT_SECRET_KEY=a7f3c9e2b8d1406f91e54acb30d67bf18e42c503f6a9123456789abcdef01234567890fedcba
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# App
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Frontend (Vite; used at docker compose build time for the production nginx image)
VITE_API_URL=http://localhost:8000/api/v1
